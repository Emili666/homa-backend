{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Dashboard principal de HOMA — Métricas de negocio y rendimiento del backend",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🏠 Estado General",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]},
          "mappings": [{"type": "value", "options": {"0": {"text": "🔴 CAÍDO"}, "1": {"text": "🟢 ACTIVO"}}}]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Estado Backend",
      "type": "stat",
      "targets": [{ "expr": "up{job='homa-backend'}", "legendFormat": "Backend", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "Peticiones / segundo",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job='homa-backend'}[5m]))", "legendFormat": "req/s", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "red", "value": 2}
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Latencia p95",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job='homa-backend'}[5m])) by (le))", "legendFormat": "p95", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.01},
            {"color": "red", "value": 0.05}
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Tasa de Errores 5xx",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job='homa-backend',status=~'5..'}[5m])) / sum(rate(http_server_requests_seconds_count{job='homa-backend'}[5m]))", "legendFormat": "Error Rate", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.7},
            {"color": "red", "value": 0.85}
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Uso Heap JVM",
      "type": "stat",
      "targets": [{ "expr": "jvm_memory_used_bytes{job='homa-backend',area='heap'} / jvm_memory_max_bytes{job='homa-backend',area='heap'}", "legendFormat": "Heap", "datasource": "Prometheus" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📊 Métricas de Negocio HOMA",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 6 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "value" },
      "title": "👤 Usuarios Activos",
      "type": "stat",
      "targets": [{ "expr": "homa_usuarios_activos", "legendFormat": "Activos", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 6 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "value" },
      "title": "🏘️ Alojamientos Activos",
      "type": "stat",
      "targets": [{ "expr": "homa_alojamientos_activos", "legendFormat": "Activos", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null},{"color": "yellow","value": 10},{"color": "red","value": 50}]}
      }},
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 6 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "⏳ Reservas Pendientes",
      "type": "stat",
      "targets": [{ "expr": "homa_reservas_pendientes", "legendFormat": "Pendientes", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 6 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "✅ Reservas Confirmadas",
      "type": "stat",
      "targets": [{ "expr": "homa_reservas_confirmadas_gauge", "legendFormat": "Confirmadas", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 6 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "🔑 Logins Exitosos",
      "type": "stat",
      "targets": [{ "expr": "increase(homa_logins_total{resultado='exitoso'}[24h])", "legendFormat": "Últimas 24h", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null},{"color": "yellow","value": 5},{"color": "red","value": 20}]}
      }},
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 6 },
      "id": 15,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "❌ Logins Fallidos",
      "type": "stat",
      "targets": [{ "expr": "increase(homa_logins_total{resultado='fallido'}[24h])", "legendFormat": "Últimas 24h", "datasource": "Prometheus" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 102,
      "title": "📈 Tráfico y Rendimiento HTTP",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Peticiones HTTP por Endpoint (req/s)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by(uri) (rate(http_server_requests_seconds_count{job='homa-backend'}[5m]))", "legendFormat": "{{ uri }}", "datasource": "Prometheus" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 21,
      "title": "Latencia por Percentil (global)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job='homa-backend'}[5m])) by (le))", "legendFormat": "p50", "datasource": "Prometheus" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job='homa-backend'}[5m])) by (le))", "legendFormat": "p95", "datasource": "Prometheus" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job='homa-backend'}[5m])) by (le))", "legendFormat": "p99", "datasource": "Prometheus" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 103,
      "title": "🖥️ Recursos JVM y Base de Datos",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "id": 30,
      "title": "Memoria JVM (Heap)",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{job='homa-backend',area='heap'}", "legendFormat": "Usado", "datasource": "Prometheus" },
        { "expr": "jvm_memory_max_bytes{job='homa-backend',area='heap'}", "legendFormat": "Máximo", "datasource": "Prometheus" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "id": 31,
      "title": "Conexiones BD (HikariCP)",
      "type": "timeseries",
      "targets": [
        { "expr": "hikaricp_connections_active{job='homa-backend'}", "legendFormat": "Activas", "datasource": "Prometheus" },
        { "expr": "hikaricp_connections_idle{job='homa-backend'}", "legendFormat": "Inactivas", "datasource": "Prometheus" },
        { "expr": "hikaricp_connections_max{job='homa-backend'}", "legendFormat": "Máximo", "datasource": "Prometheus" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "id": 32,
      "title": "Threads JVM",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_threads_live_threads{job='homa-backend'}", "legendFormat": "Activos", "datasource": "Prometheus" },
        { "expr": "jvm_threads_peak_threads{job='homa-backend'}", "legendFormat": "Pico", "datasource": "Prometheus" },
        { "expr": "jvm_threads_daemon_threads{job='homa-backend'}", "legendFormat": "Daemon", "datasource": "Prometheus" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 105,
      "title": "📅 Gestión de Reservas (ISO/IEC 25010)",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null},{"color": "yellow","value": 10},{"color": "red","value": 50}]}
      }},
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 29 },
      "id": 50,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "⏳ Pendientes",
      "type": "stat",
      "targets": [{ "expr": "homa_reservas_pendientes", "legendFormat": "Pendientes", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null}]}
      }},
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 29 },
      "id": 51,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "✅ Confirmadas",
      "type": "stat",
      "targets": [{ "expr": "homa_reservas_confirmadas_gauge", "legendFormat": "Confirmadas", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null}]}
      }},
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 29 },
      "id": 52,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "🏁 Completadas",
      "type": "stat",
      "targets": [{ "expr": "homa_reservas_completadas_gauge", "legendFormat": "Completadas", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null},{"color": "yellow","value": 5},{"color": "red","value": 20}]}
      }},
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 29 },
      "id": 53,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "❌ Canceladas",
      "type": "stat",
      "targets": [{ "expr": "homa_reservas_canceladas_gauge", "legendFormat": "Canceladas", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 29 },
      "id": 54,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "🔍 Consultas Disponibilidad (24h)",
      "type": "stat",
      "targets": [{ "expr": "increase(homa_disponibilidad_consultas_total[24h])", "legendFormat": "Consultas", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null},{"color": "yellow","value": 0.3},{"color": "red","value": 0.5}]}
      }},
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 29 },
      "id": 55,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "🚫 Tasa No Disponibilidad",
      "type": "stat",
      "targets": [{ "expr": "increase(homa_disponibilidad_no_disponible_total[24h]) / increase(homa_disponibilidad_consultas_total[24h])", "legendFormat": "No disponible", "datasource": "Prometheus" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 56,
      "title": "📊 Flujo de Reservas por Estado (últimas 24h)",
      "type": "timeseries",
      "targets": [
        { "expr": "increase(homa_reservas_total{accion='creada'}[1h])", "legendFormat": "Creadas", "datasource": "Prometheus" },
        { "expr": "increase(homa_reservas_total{accion='confirmada'}[1h])", "legendFormat": "Confirmadas", "datasource": "Prometheus" },
        { "expr": "increase(homa_reservas_total{accion='completada'}[1h])", "legendFormat": "Completadas", "datasource": "Prometheus" },
        { "expr": "increase(homa_reservas_total{accion='cancelada'}[1h])", "legendFormat": "Canceladas", "datasource": "Prometheus" },
        { "expr": "increase(homa_reservas_total{accion='rechazada'}[1h])", "legendFormat": "Rechazadas", "datasource": "Prometheus" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 },
        "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null},{"color": "yellow","value": 1},{"color": "red","value": 3}]}
      }},
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 57,
      "title": "⏱️ Tiempo de Creación de Reserva (RNF-REN-09)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(homa_reserva_creacion_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "datasource": "Prometheus" },
        { "expr": "histogram_quantile(0.95, sum(rate(homa_reserva_creacion_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95 (objetivo ≤ 1.5s)", "datasource": "Prometheus" },
        { "expr": "histogram_quantile(0.99, sum(rate(homa_reserva_creacion_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "datasource": "Prometheus" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 58,
      "title": "🌙 Total Noches Reservadas (Análisis Negocio)",
      "type": "timeseries",
      "targets": [
        { "expr": "homa_reserva_noches_total_total", "legendFormat": "Noches acumuladas", "datasource": "Prometheus" },
        { "expr": "rate(homa_reserva_noches_total_total[1h]) * 3600", "legendFormat": "Noches por hora", "datasource": "Prometheus" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 59,
      "title": "💰 Ingresos Acumulados por Reservas COP (Análisis Negocio)",
      "type": "timeseries",
      "targets": [
        { "expr": "homa_reserva_ingresos_total_total", "legendFormat": "Ingresos acumulados (COP)", "datasource": "Prometheus" },
        { "expr": "rate(homa_reserva_ingresos_total_total[1h]) * 3600", "legendFormat": "Ingresos por hora (COP)", "datasource": "Prometheus" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "id": 106,
      "title": "💳 Sistema de Pagos (MercadoPago)",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
