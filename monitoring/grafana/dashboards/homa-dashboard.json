            {"color": "green", "value": 1}
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 50 },
      "id": 60,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "noValue": "0" },
