# ============================================================
# HOMA Backend — Variables de entorno para Docker / Producción
# Copia como .env y completa los valores reales
# NUNCA subas el .env al repositorio
# ============================================================

# Base de datos
DB_HOST=tu_host_db
DB_PORT=3306
DB_NAME=homa_db
DB_USERNAME=homa_user
DB_PASSWORD=contraseña_segura
DB_USE_SSL=true
DB_REQUIRE_SSL=true

# JPA
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# JWT (mínimo 32 caracteres, generado aleatoriamente)
JWT_SECRET=genera-un-secreto-aleatorio-seguro-aqui
JWT_EXPIRATION=3600000

# Correo
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password

# URLs
FRONTEND_BASE_URL=https://tu-frontend.com
BACKEND_BASE_URL=https://tu-backend.com
CORS_ALLOWED_ORIGINS=https://tu-frontend.com

# Mapbox
MAPBOX_TOKEN=tu_mapbox_token

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=tu_access_token_mp
MERCADO_PAGO_PUBLIC_KEY=tu_public_key_mp
MERCADO_PAGO_BACK_URL_SUCCESS=https://tu-frontend.com/success
MERCADO_PAGO_BACK_URL_PENDING=https://tu-frontend.com/pending
MERCADO_PAGO_BACK_URL_FAILURE=https://tu-frontend.com/failure

# Cloudflare Turnstile
TURNSTILE_SECRET=tu_turnstile_secret

# Administrador inicial
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=ContraseñaSegura123!

# Grafana Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=contraseña_grafana_segura
GRAFANA_ROOT_URL=http://tu-servidor:3030

# Prometheus — host del backend para scraping
HOMA_BACKEND_HOST=tu-backend.com

# SonarQube
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=tu_sonar_token
