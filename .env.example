# --- CONFIGURACION GENERAL ---
SPRING_PROFILES_ACTIVE=prod
CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app,http://localhost:4200

# --- CONFIGURACION BASE DE DATOS (VPS) ---
DB_HOST=tu_ip_vps
DB_PORT=3306
DB_NAME=homa_avanzada_db
DB_USERNAME=homa_user
DB_PASSWORD=tu_password_seguro
DB_ROOT_PASSWORD=password_root_vps

# --- CONFIGURACION BACKEND (Clave Secreta) ---
JWT_SECRET=una_clave_muy_larga_y_segura_para_produccion
JWT_EXPIRATION=3600000

# --- SMTP (Correo) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password

# --- CLOUDINARY ---
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER=alojamientos

# --- MAPBOX ---
MAPBOX_TOKEN=tu_mapbox_token

# --- URLs ---
FRONTEND_BASE_URL=https://tu-frontend.vercel.app
BACKEND_BASE_URL=https://tu-backend.railway.app
